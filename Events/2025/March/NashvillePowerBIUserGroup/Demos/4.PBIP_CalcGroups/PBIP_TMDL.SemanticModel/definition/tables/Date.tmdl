	/// Number of days offset from today, future days positive and prior days negative.
	column 'Today Day Offset'
		formatString: 0
		displayFolder: Offset to today
		lineageTag: ebf38397-722e-4f50-91ee-a5a7fb03686d
		summarizeBy: none
