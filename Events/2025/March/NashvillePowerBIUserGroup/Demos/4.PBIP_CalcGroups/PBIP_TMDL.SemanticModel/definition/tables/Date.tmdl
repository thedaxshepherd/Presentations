		sourceColumn: [Year Month]
		sortByColumn: Monthly

	/// Each week starting Sunday displayed as start of week to end of week in format dd mmm 'yy - dd mmm 'yy. Sort correctly with ORDER BY CALCULATE(MIN('Date'[Weekly]))
	column Week
